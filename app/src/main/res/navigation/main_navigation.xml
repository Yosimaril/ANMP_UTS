<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    android:label="Welcome"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.an.habittracker.view.LoginFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/actionLoginFragmentToDashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.an.habittracker.view.DashboardFragment"
        android:label="Your Habits"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/actionDashboardFragmentToNewHabitFragment"
            app:destination="@id/newHabitFragment" />
    </fragment>
    <fragment
        android:id="@+id/newHabitFragment"
        android:name="com.an.habittracker.view.NewHabitFragment"
        android:label="Create New Habit"
        tools:layout="@layout/fragment_new_habit" />
</navigation>